Given an integer array nums, you need to find one continuous subarray such that if you only sort this subarray in non-decreasing order, 
then the whole array will be sorted in non-decreasing order.
Return the shortest such subarray and output its length.

Example 1:
Input: nums = [2,6,4,8,10,9,15]
Output: 5
Explanation: You need to sort [6, 4, 8, 10, 9] in ascending order to make the whole array sorted in ascending order.

Example 2:
Input: nums = [1,2,3,4]
Output: 0

Example 3:
Input: nums = [1]
Output: 0

Constraints:
1 <= nums.length <= 104
-105 <= nums[i] <= 105

Follow up: Can you solve it in O(n) time complexity?

Code:
class Solution {
public:
    int findUnsortedSubarray(vector<int>& nums) {
        int n = nums.size();
        int left = -1;
        int right = -1;

        for(int i=1;i<n;i++){
            if(nums[i] < nums[i-1]){
                left = i-1;
                break;
            }
        }

        for(int i=n-1;i>0;i--){
            if(nums[i] < nums[i-1]){
                right = i;
                break;
            }
        }

        if(left == -1){
            return 0;
        }

        int mini = INT_MAX, maxi = INT_MIN;
        for(int i=left;i<=right;i++){
            mini = min(mini, nums[i]);
            maxi = max(maxi, nums[i]);
        }

        while(left > 0 && nums[left-1] > mini){
            left--;
        }

         while(right < n- 1 && nums[right+1] < maxi){
            right++;
        }
    

        return right - left +1;
    }
};
